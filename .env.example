# App
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Backend talks to this origin (CORS allowlist). Nuxt dev server runs on 3000.
WEB_URL=http://localhost:3000
APP_URL=http://localhost:3001

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mnemio
POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mnemio

# Auth
JWT_SECRET=replace-with-at-least-32-characters-of-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Mail (console = log to stdout; useful for dev)
MAIL_PROVIDER=console
MAIL_FROM="Mnemio <noreply@mnemio.local>"
# MAIL_PROVIDER_API_KEY=

# OAuth (optional at MVP)
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_FACEBOOK_CLIENT_ID=
# OAUTH_FACEBOOK_CLIENT_SECRET=
# OAUTH_APPLE_CLIENT_ID=
# OAUTH_APPLE_TEAM_ID=
# OAUTH_APPLE_KEY_ID=
# OAUTH_APPLE_PRIVATE_KEY=
