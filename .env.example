# App
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Backend talks to this origin (CORS allowlist). Nuxt dev server runs on 3000.
WEB_URL=http://localhost:3000
# Optional CSV allowlist for multiple frontend domains.
# Example: WEB_URLS=https://app.mnemio.com,https://www.mnemio.com
# When set, WEB_URL is ignored for CORS matching.
# WEB_URLS=
WEB_URLS=http://localhost:3000
APP_URL=http://localhost:3001

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mnemio
POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mnemio

# Auth
JWT_SECRET=replace-with-at-least-32-characters-of-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Mail
# 'console'  → log to stdout; useful for dev (OTP visible in backend logs).
# 'resend'   → real transactional mail; requires MAIL_PROVIDER_API_KEY (re_…)
#              and MAIL_FROM on a verified Resend domain.
MAIL_PROVIDER=console
MAIL_FROM="Mnemio <noreply@mnemio.local>"
# MAIL_PROVIDER_API_KEY=re_xxxxxxxxxxxx

# Observability (optional — when unset, Sentry plugin no-ops)
# SENTRY_DSN=

# OAuth (Google) — uncomment all three to enable.
# Get CLIENT_ID + SECRET at https://console.cloud.google.com/apis/credentials
# REDIRECT_URL must match the entry in the OAuth client's "Authorized
# redirect URIs" (i.e. http://localhost:3001/api/v1/auth/oauth/google/callback
# in dev, https://<your-api-host>/api/v1/auth/oauth/google/callback in prod).
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GOOGLE_REDIRECT_URL=http://localhost:3001/api/v1/auth/oauth/google/callback
# OAUTH_FACEBOOK_CLIENT_ID=
# OAUTH_FACEBOOK_CLIENT_SECRET=
# OAUTH_APPLE_CLIENT_ID=
# OAUTH_APPLE_TEAM_ID=
# OAUTH_APPLE_KEY_ID=
# OAUTH_APPLE_PRIVATE_KEY=

# AI
# 'mock' returns deterministic placeholders (no key needed).
# 'anthropic' calls Anthropic Claude — requires ANTHROPIC_API_KEY.
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Per-user daily caps
AI_DAILY_ENRICH_CAP_PER_USER=5
AI_DAILY_GENERATE_CAP_PER_USER=20
AI_DAILY_SUGGEST_CAP_PER_USER=60
AI_MAX_WORDS_PER_ENRICH=100

# Real-time chat
AI_DAILY_CHAT_CAP_PER_USER=50
AI_CHAT_CONTEXT_TURNS=20
AI_CHAT_MAX_OUTPUT_TOKENS=1024

# Imports (Quizlet / paste-text) — shares the ai_usage table
IMPORT_DAILY_CAP_PER_USER=20
IMPORT_FETCH_TIMEOUT_MS=10000
IMPORT_MAX_BYTES=2000000

# Stripe billing — uncomment and fill in to enable subscriptions.
# Get keys at https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_ANNUAL=price_...

# Premium plan daily AI caps (defaults = 10× free)
# AI_DAILY_ENRICH_CAP_PREMIUM_PER_USER=50
# AI_DAILY_GENERATE_CAP_PREMIUM_PER_USER=200
# AI_DAILY_SUGGEST_CAP_PREMIUM_PER_USER=600
# AI_DAILY_CHAT_CAP_PREMIUM_PER_USER=500
# IMPORT_DAILY_CAP_PREMIUM_PER_USER=200