// Per-user achievement unlocks. The catalog (id/name/description/icon/criteria)
// lives in code at src/services/achievements.catalog.ts — there's no value in
// keeping it in the DB since FE just renders the list and the criteria are
// evaluated in JS.
model UserAchievement {
  userId    String
  key       String   // catalog key, e.g. 'first_steps'
  earnedAt  DateTime?
  progress  Int      @default(0)   // 0..100 percent, or counter, depending on achievement
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, key])
  @@index([userId, earnedAt])
  @@map("user_achievements")
}
