// Per-user daily AI usage rollup. One row per (user, calendar day UTC, kind).
// Atomically incremented at the start of each successful AI call so the cap
// holds even under concurrent requests. Used by ai.budget.service.ts.
model AiUsage {
  userId    String
  day       DateTime @db.Date     // UTC midnight
  kind      String                // 'enrich' | 'generate' | 'suggest'
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, day, kind])
  @@index([userId, day])
  @@map("ai_usage")
}
