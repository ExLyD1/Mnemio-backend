model Card {
  id                 String   @id @default(uuid())
  userId             String
  deckId             String
  word               String
  definition         String
  phonetic           String?
  reading            String?
  partOfSpeech       String?
  example            String?
  exampleTranslation String?
  tags               String[] @default([])
  difficulty         String   @default("medium")
  type               String   @default("basic")
  audioUrl           String?
  imageUrl           String?
  position           Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck           Deck           @relation(fields: [deckId], references: [id], onDelete: Cascade)
  cardProgresses CardProgress[]

  @@index([deckId, position])
  @@map("cards")
}

model CardProgress {
  userId         String
  cardId         String
  interval       Int       @default(0)
  easeFactor     Float     @default(2.5)
  repetitions    Int       @default(0)
  nextReviewAt   DateTime  @default(now())
  lastReviewedAt DateTime?
  // Set-once when the card first reaches mastery (repetitions >= 3). Never
  // overwritten, never cleared on lapse — powers the cumulative "mastery curve"
  // (GET /stats/card-series). CardProgress is upsert-only with no history, so
  // this is the only record of *when* mastery was first achieved.
  masteredAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@id([userId, cardId])
  @@index([userId, nextReviewAt])
  @@map("card_progresses")
}
