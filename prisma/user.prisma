model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?
  fullName        String?
  username        String?   @unique
  birthday        DateTime? @db.Date
  avatarUrl       String?
  role            String    @default("user")
  emailVerifiedAt DateTime?
  xp              Int       @default(0)
  streak          Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  cards               Card[]
  decks               Deck[]
  folders             Folder[]
  cardProgresses      CardProgress[]
  studySessions       StudySession[]
  achievements        Achievement[]
  deckCollaborators   DeckCollaborator[]
  folderCollaborators FolderCollaborator[]
  refreshTokens       RefreshToken[]
  emailVerifications  EmailVerification[]
  oauthIdentities     OAuthIdentity[]
  auditLogs           AuditLog[]

  @@map("users")
}

model Achievement {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String
  iconUrl     String
  unlockedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

model StudySession {
  id              String   @id @default(uuid())
  userId          String
  deckId          String
  mode            String
  status          String   @default("active")
  cardIds         String[]
  cardIndex       Int      @default(0)
  correct         Int      @default(0)
  xpAwarded       Int      @default(0)
  cardsStudied    Int      @default(0)
  correctAnswers  Int      @default(0)
  duration        Int      @default(0)
  // Per-grade tally — server-backed Session Summary (replaces FE usePractice).
  countsAgain     Int      @default(0)
  countsHard      Int      @default(0)
  countsGood      Int      @default(0)
  countsEasy      Int      @default(0)
  revisitCardIds  String[]
  durationMs      Int      @default(0)
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  completedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("study_sessions")
}
