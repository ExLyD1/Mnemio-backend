model Deck {
  id             String   @id @default(uuid())
  authorId       String
  title          String
  description    String   @default("")
  sourceLanguage String
  targetLanguage String
  isPublic       Boolean  @default(false)
  cardCount      Int      @default(0)
  // Cosmetic / discovery fields (P2)
  coverColor     String?
  glyph          String?
  subject        String?
  // Featured by curators for the Discover landing — toggle by an admin in DB
  // for MVP; eventual surface: POST /admin/decks/:id/feature.
  featured       Boolean  @default(false)
  copyCount      Int      @default(0)
  sourceDeckId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  author        User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  cards         Card[]
  studySessions StudySession[]
  collaborators DeckCollaborator[]
  folderDecks   FolderDeck[]
  copies        Deck[]             @relation("DeckCopies")
  source        Deck?              @relation("DeckCopies", fields: [sourceDeckId], references: [id], onDelete: SetNull)

  @@index([authorId, updatedAt])
  @@index([isPublic, updatedAt])
  @@index([isPublic, subject])
  @@index([isPublic, featured])
  @@map("decks")
}

model DeckCollaborator {
  id        String   @id @default(uuid())
  deckId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([deckId, userId])
  @@map("deck_collaborators")
}
