model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?
  event      String
  ip         String?
  userAgent  String?
  details    Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@map("audit_log")
}
